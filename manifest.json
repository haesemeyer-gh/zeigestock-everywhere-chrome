{
    "name": "Zeigestock Everywhere",
    "description": "zeigestock.js for chrome",
    "author": "haesemeyer <haesemeyer@mailbox.org>",
    "version": "1.2",
    "manifest_version": 3,
    "icons": {
        "16": "assets/icon-16.png",
        "32": "assets/icon-32.png",
        "48": "assets/icon-48.png",
        "128": "assets/icon-128.png"
    },
    "action": {
        "default_title": "Zeigestock Everywhere"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*/*"
            ],
            "js": [
                "scripts/zeigestock_import.js"
            ],
            "run_at": "document_end",
            "world": "MAIN"
        }
    ]
}
