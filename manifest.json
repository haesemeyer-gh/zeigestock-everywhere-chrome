{
    "name": "Zeigestock Everywhere",
    "description": "zeigestock.js for browsers",
    "author": "haesemeyer <haesemeyer@mailbox.org>",
    "version": "2.0",
    "manifest_version": 3,
    "browser_specific_settings": {
        "gecko": {
            "id": "c35f0e3097a2455aaf2f7d5ccdefd93437c7f6a0@temporary-addon",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "icons": {
        "16": "assets/icon-16.png",
        "32": "assets/icon-32.png",
        "48": "assets/icon-48.png",
        "128": "assets/icon-128.png"
    },
    "action": {
        "default_title": "Zeigestock Everywhere"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*/*"
            ],
            "js": [
                "scripts/zeigestock_ext.js"
            ],
            "run_at": "document_end",
            "world": "MAIN"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["assets/zeigestock.png"],
            "matches": ["*://*/*"]
        }
    ]
}
